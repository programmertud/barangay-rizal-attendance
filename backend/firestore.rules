rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /officials/{id} {
      allow read, write: if signedIn();
    }

    match /bhw/{id} {
      allow read, write: if signedIn();
    }

    match /tanod/{id} {
      allow read, write: if signedIn();
    }

    match /attendance/{id} {
      allow read, write: if signedIn();
    }

    match /rfidScans/{id} {
      allow read, write: if signedIn();
    }

    match /system/{id} {
      allow read, write: if signedIn();
    }
  }
}
